<?xml version="1.0" ?>
<sdf version="1.6">
  <model name='sambirion'>

    <!-- The base_link is a common convention in ROS for a non-colliding link at ground level. -->
    <link name='base_link'>
      <pose>0 0 0 0 0 0</pose>
    </link>

    <!-- This joint rigidly connects the chassis to the base_link. -->
    <joint name='base_link_to_chassis' type='fixed'>
      <parent>base_link</parent>
      <child>chassis</child>
    </joint>

    <link name='chassis'>
        <pose>0 0 0.0875 0 0 0</pose>
      <inertial>
        <mass>1.14395</mass>
        <inertia>
          <ixx>0.126164</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.416519</iyy>
          <iyz>0</iyz>
          <izz>0.481014</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <geometry>
          <box>
            <size>0.65 0.245 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.5 0.5 1.0 1</ambient>
          <diffuse>0.5 0.5 1.0 1</diffuse>
          <specular>0.0 0.0 1.0 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <box>
            <size>0.65 0.245 0.05</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- Wheel Links -->
    <link name='front_left_wheel'>
        <pose relative_to="chassis">0.2 0.1625 0 -1.5707 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.145833</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.145833</iyy>
          <iyz>0</iyz>
          <izz>0.125</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <mesh>
            <uri>/root/sambirion/src/sambirion_description/models/sambirion/meshes/mecanum_wheel_left.STL</uri>
            <scale>0.002 0.002 0.002</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <sphere>
            <radius>0.1</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <!-- The friction direction for Mecanum wheels is complex and often handled by plugins. -->
              <!-- This fdir1 is a simplification. -->
              <fdir1>1 -1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='rear_left_wheel'>
        <pose relative_to="chassis">-0.2 0.1625 0 -1.5707 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.145833</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.145833</iyy>
          <iyz>0</iyz>
          <izz>0.125</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <mesh>
            <uri>/root/sambirion/src/sambirion_description/models/sambirion/meshes/mecanum_wheel_right.STL</uri>
            <scale>0.002 0.002 0.002</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <sphere>
            <radius>0.1</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1>1 1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='front_right_wheel'>
        <pose relative_to="chassis">0.2 -0.1625 0 -1.5707 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.145833</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.145833</iyy>
          <iyz>0</iyz>
          <izz>0.125</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <mesh>
            <uri>/root/sambirion/src/sambirion_description/models/sambirion/meshes/mecanum_wheel_right.STL</uri>
            <scale>0.002 0.002 0.002</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <sphere>
            <radius>0.1</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1>1 1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <link name='rear_right_wheel'>
        <pose relative_to="chassis">-0.2 -0.1625 0 -1.5707 0 0</pose>
      <inertial>
        <mass>2</mass>
        <inertia>
          <ixx>0.145833</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.145833</iyy>
          <iyz>0</iyz>
          <izz>0.125</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <pose>0 0 0 1.5707 0 0</pose>
        <geometry>
          <mesh>
            <uri>/root/sambirion/src/sambirion_description/models/sambirion/meshes/mecanum_wheel_left.STL</uri>
            <scale>0.002 0.002 0.002</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>
      <collision name='collision'>
        <geometry>
          <sphere>
            <radius>0.1</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.0</mu2>
              <fdir1>1 -1 0</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Wheel Joints -->
    <joint name='front_left_wheel_joint' type='revolute'>
      <parent>chassis</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name='front_right_wheel_joint' type='revolute'>
      <parent>chassis</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name='rear_left_wheel_joint' type='revolute'>
      <parent>chassis</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name='rear_right_wheel_joint' type='revolute'>
      <parent>chassis</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <!-- Front Lidar Sensor -->
    <link name="front_lidar_link">
        <pose relative_to="chassis">0.325 0 0.045 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.000166667</ixx>
          <iyy>0.000166667</iyy>
          <izz>0.000166667</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.0 1.0 0.0 1</ambient>
          <diffuse>0.0 1.0 0.0 1</diffuse>
          <specular>0.0 1.0 0.0 1</specular>
        </material>
      </visual>
      <!-- The sensor definition for Gazebo Classic -->
      <sensor name='front_gpu_lidar' type='ray'>
        <pose>0 0 0 0 0 0</pose>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>640</samples>
              <resolution>1</resolution>
              <min_angle>-1.396263</min_angle>
              <max_angle>1.396263</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.08</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <visualize>true</visualize>
        <!-- The plugin that connects the sensor to ROS -->
       <plugin name="gazebo_ros_front_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=/front_scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>front_lidar_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name='front_lidar_joint' type='fixed'>
      <parent>chassis</parent>
      <child>front_lidar_link</child>
    </joint>

    <!-- Rear Lidar Sensor -->
    <link name="rear_lidar_link">
        <pose relative_to="chassis">-0.325 0 0.045 0 0 3.14159</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.000166667</ixx>
          <iyy>0.000166667</iyy>
          <izz>0.000166667</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1.0 0.0 0.0 1</ambient>
          <diffuse>1.0 0.0 0.0 1</diffuse>
          <specular>1.0 0.0 0.0 1</specular>
        </material>
      </visual>
      <!-- The sensor definition for Gazebo Classic -->
      <sensor name='rear_gpu_lidar' type='ray'>
        <pose>0 0 0 0 0 0</pose>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>640</samples>
              <resolution>1</resolution>
              <min_angle>-1.396263</min_angle>
              <max_angle>1.396263</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.08</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <visualize>true</visualize>
        <!-- The plugin that connects the sensor to ROS -->
        <plugin name="gazebo_ros_rear_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=/rear_scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>rear_lidar_link</frame_name>
        </plugin>

      </sensor>
    </link>

    <joint name='rear_lidar_joint' type='fixed'>
      <parent>chassis</parent>
      <child>rear_lidar_link</child>
    </joint>

    <!-- The Gazebo Classic plugin for Mecanum drive -->
    <!-- Note: This is a common community plugin. Ensure it's installed or use an alternative like gazebo_ros_control. -->
    <plugin name="planar_move_controller" filename="libgazebo_ros_planar_move.so">
  <ros>
    <namespace>/</namespace>
    <remapping>cmd_vel:=cmd_vel</remapping>
    <remapping>odom:=odom</remapping>
  </ros>
  <command_topic>cmd_vel</command_topic>
  <odometry_topic>odom</odometry_topic>
  <odometry_frame>odom</odometry_frame>
  <robot_base_frame>base_link</robot_base_frame>
  <publish_odometry>true</publish_odometry>
  <publish_odom_tf>true</publish_odom_tf>
</plugin>


  </model>
</sdf>